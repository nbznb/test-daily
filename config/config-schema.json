{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "User configuration for USTC Daily News. Stored at ~/.ustc-dailynews/config.json",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["openclaw", "other"],
      "description": "Detected platform"
    },
    "language": {
      "type": "string",
      "enum": ["en", "zh", "bilingual"],
      "default": "zh",
      "description": "Digest language"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Shanghai",
      "description": "IANA timezone string"
    },
    "frequency": {
      "type": "string",
      "enum": ["daily", "weekly"],
      "default": "daily",
      "description": "How often to deliver the digest"
    },
    "deliveryTime": {
      "type": "string",
      "default": "08:00",
      "description": "Time of day in HH:MM"
    },
    "weeklyDay": {
      "type": "string",
      "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
      "default": "monday",
      "description": "Day of week for weekly digests"
    },
    "selectedDepartments": {
      "type": "array",
      "description": "Department names to include in the digest. Default is one department: 少年班学院.",
      "default": ["少年班学院"],
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "delivery": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["stdout", "telegram", "email"],
          "default": "stdout"
        },
        "chatId": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "onboardingComplete": {
      "type": "boolean",
      "default": false
    }
  }
}
